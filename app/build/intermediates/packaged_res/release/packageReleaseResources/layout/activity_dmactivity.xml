<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface"
    tools:context=".ChatActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/header_card"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="10dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/gobackbtn"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="5dp"
                android:text="@string/go_back"
                android:textSize="16sp"
                app:icon="@drawable/btn15036" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Messages Display Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/header_card"
        app:layout_constraintBottom_toTopOf="@id/MessageRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow">

            <TextView
                android:id="@+id/MessageStream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/messages_will_show_here"
                android:padding="8dp"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textIsSelectable="true"
                android:gravity="top"
                android:minHeight="200dp" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.core.widget.NestedScrollView>

    <!-- Message Input Container -->
    <LinearLayout
        android:id="@+id/MessageRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="13dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/input_background"
        android:padding="4dp"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/Messageinput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="13dp"
            android:layout_weight="1"
            android:layout_marginTop="7dp"
            android:autofillHints="Hello"
            android:hint="@string/type_your_message_here"
            android:inputType="text"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/Sendtxt"
            android:layout_width="58dp"
            android:layout_height="59dp"
            android:layout_marginEnd="3dp"
            android:contentDescription="@string/send_button"
            android:src="@drawable/sendbtn"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>